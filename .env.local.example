# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and used for local development.
# For Vercel, add the same variables in Project Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Supabase (Project Settings → API)
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, never expose to the client
# Used for admin operations if needed; keep secret
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Anthropic Claude API
# https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------

# Server-only API key for calorie estimation (text + vision)
ANTHROPIC_API_KEY=

# Model ID for structured JSON output (do not hardcode in source)
CLAUDE_MODEL_ID=claude-sonnet-5
